{
  "compilerOptions": {
    "allowSyntheticDefaultImports": true,
    "esModuleInterop": true,
    "noEmit": true,
    "strict": false,
    "strictNullChecks": false,
    "strictFunctionTypes": false,
    "jsx": "react",
    "moduleResolution": "bundler",
    "module": "preserve",
    "target": "es2020",
    "lib": [
      "es2020",
      "dom",
      "dom.iterable"
    ],
    "skipLibCheck": true
  },
  "include": [
    "./*.tsx"
  ]
}
