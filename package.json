{
  "name": "react-dropzone",
  "version": "0.0.0-development",
  "description": "Simple HTML5 drag-drop zone with React.js",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./typings/react-dropzone.d.ts",
  "exports": {
    ".": {
      "types": "./typings/react-dropzone.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./package.json": "./package.json"
  },
  "sideEffects": false,
  "files": [
    "dist",
    "src",
    "typings",
    "!src/**/*.spec.*"
  ],
  "keywords": [
    "react-component",
    "react",
    "drag",
    "drop",
    "upload"
  ],
  "homepage": "https://github.com/react-dropzone/react-dropzone",
  "repository": {
    "type": "git",
    "url": "https://github.com/react-dropzone/react-dropzone.git"
  },
  "bugs": {
    "url": "https://github.com/react-dropzone/react-dropzone/issues"
  },
  "author": "Param Aggarwal",
  "contributors": [
    "Andrey Okonetchnikov <andrey@okonet.ru> (http://okonet.ru)",
    "Mike Olson <me@mwolson.org>",
    "Param Aggarwal",
    "Tyler Waters <tyler.waters@gmail.com>",
    "Rick Markins <rmarkins@gmail.com>",
    "Roland Groza <rolandjitsu@gmail.com>"
  ],
  "license": "MIT",
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "prepare": "husky",
    "prebuild": "npm run clean",
    "build": "tsdown",
    "dev": "tsdown --watch",
    "clean": "rm -rf dist",
    "type-check": "tsc --noEmit -p typings/tests/tsconfig.json",
    "lint": "oxlint",
    "lint:fix": "oxlint --fix",
    "lint:type-aware": "oxlint --type-aware",
    "format": "oxfmt vitest.config.ts tsdown.config.ts vocs.config.ts",
    "format:check": "oxfmt --check vitest.config.ts tsdown.config.ts vocs.config.ts",
    "pretest:cov": "npm run type-check && npm run lint && npm run format:check",
    "test": "vitest",
    "test:cov": "vitest run --coverage",
    "docs:dev": "vocs dev",
    "docs:build": "vocs build",
    "docs:preview": "vocs preview"
  },
  "peerDependencies": {
    "react": ">= 16.8 || 18.0.0"
  },
  "dependencies": {
    "attr-accept": "^2.2.5",
    "file-selector": "^2.1.0",
    "prop-types": "^15.8.1"
  },
  "devDependencies": {
    "@commitlint/cli": "^19.0.0",
    "@commitlint/config-conventional": "^19.0.0",
    "@semantic-release/changelog": "^6.0.0",
    "@semantic-release/commit-analyzer": "^12.0.0",
    "@semantic-release/github": "^10.0.0",
    "@semantic-release/npm": "^13.1.3",
    "@semantic-release/release-notes-generator": "^14.1.0",
    "@testing-library/dom": "^10.0.0",
    "@testing-library/jest-dom": "^6.0.0",
    "@testing-library/react": "^16.3.2",
    "@types/node": "^26.1.1",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitest/coverage-v8": "^4.1.10",
    "husky": "^9.1.0",
    "jsdom": "^29.1.1",
    "oxfmt": "^0.58.0",
    "oxlint": "^1.73.0",
    "oxlint-tsgolint": "^0.24.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "semantic-release": "^25.0.2",
    "styled-components": "^6.4.3",
    "tsdown": "^0.22.4",
    "typescript": "^7.0.2",
    "vitest": "^4.1.10",
    "vocs": "^2.5.3",
    "waku": "^1.0.0-beta.6"
  },
  "engines": {
    "node": ">= 20"
  }
}
